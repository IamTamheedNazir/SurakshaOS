# Environment Configuration
NODE_ENV=development

# Application
APP_NAME=UmrahConnect 2.0
APP_URL=http://localhost:3000
API_URL=http://localhost:5000
PORT=5000

# Database - PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_NAME=umrahconnect
DB_USER=postgres
DB_PASSWORD=your_password_here

# Database - MongoDB
MONGO_URI=mongodb://localhost:27017/umrahconnect

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# JWT Authentication
JWT_SECRET=your_jwt_secret_key_here_change_in_production
JWT_EXPIRES_IN=7d
REFRESH_TOKEN_SECRET=your_refresh_token_secret_here
REFRESH_TOKEN_EXPIRES_IN=30d

# Payment Gateways
RAZORPAY_KEY_ID=your_razorpay_key_id
RAZORPAY_KEY_SECRET=your_razorpay_secret
STRIPE_SECRET_KEY=your_stripe_secret_key
STRIPE_PUBLISHABLE_KEY=your_stripe_publishable_key
PAYPAL_CLIENT_ID=your_paypal_client_id
PAYPAL_CLIENT_SECRET=your_paypal_secret

# WhatsApp Business API
WHATSAPP_API_URL=https://graph.facebook.com/v18.0
WHATSAPP_PHONE_NUMBER_ID=your_phone_number_id
WHATSAPP_ACCESS_TOKEN=your_whatsapp_access_token
WHATSAPP_VERIFY_TOKEN=your_verify_token

# Twilio (SMS)
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=your_twilio_phone_number

# SendGrid (Email)
SENDGRID_API_KEY=your_sendgrid_api_key
SENDGRID_FROM_EMAIL=noreply@umrahconnect.com
SENDGRID_FROM_NAME=UmrahConnect

# Google Maps
GOOGLE_MAPS_API_KEY=your_google_maps_api_key

# AWS S3 (File Storage)
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_REGION=ap-south-1
AWS_S3_BUCKET=umrahconnect-files

# Cloudflare (CDN)
CLOUDFLARE_ZONE_ID=your_cloudflare_zone_id
CLOUDFLARE_API_TOKEN=your_cloudflare_token

# Analytics
MIXPANEL_TOKEN=your_mixpanel_token
GOOGLE_ANALYTICS_ID=your_ga_id

# Security
ENCRYPTION_KEY=your_encryption_key_32_characters
BCRYPT_ROUNDS=10

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# CORS
CORS_ORIGIN=http://localhost:3000,http://localhost:3001

# Session
SESSION_SECRET=your_session_secret_here

# Elasticsearch
ELASTICSEARCH_NODE=http://localhost:9200
ELASTICSEARCH_USERNAME=elastic
ELASTICSEARCH_PASSWORD=your_elasticsearch_password

# RabbitMQ
RABBITMQ_URL=amqp://localhost:5672

# Logging
LOG_LEVEL=debug
LOG_FILE_PATH=./logs

# Feature Flags
ENABLE_WHATSAPP=true
ENABLE_SMS=true
ENABLE_EMAIL=true
ENABLE_AFFILIATE_PROGRAM=true
ENABLE_PARTIAL_PAYMENTS=true

# Commission Rates (%)
BASE_COMMISSION_RATE=2.5
UMRAH_COMMISSION=2.5
HAJJ_COMMISSION=3.0
HOTEL_COMMISSION=3.0
TRANSPORT_COMMISSION=2.0
VISA_COMMISSION=2.5

# Subscription Pricing (INR/month)
BASIC_SUBSCRIPTION=2000
PROFESSIONAL_SUBSCRIPTION=5000
ENTERPRISE_SUBSCRIPTION=12000
PLATINUM_SUBSCRIPTION=25000
