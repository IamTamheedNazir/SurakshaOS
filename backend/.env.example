# ========================================
# SERVER CONFIGURATION
# ========================================
NODE_ENV=development
PORT=5000
FRONTEND_URL=http://localhost:3000

# ========================================
# DATABASE CONFIGURATION
# ========================================
MONGODB_URI=mongodb://localhost:27017/umrahconnect
# For MongoDB Atlas:
# MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/umrahconnect?retryWrites=true&w=majority

# ========================================
# JWT CONFIGURATION
# ========================================
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRE=30d
JWT_COOKIE_EXPIRE=30

# ========================================
# EMAIL CONFIGURATION (SMTP)
# ========================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
FROM_EMAIL=noreply@umrahconnect.com
FROM_NAME=UmrahConnect

# ========================================
# PAYMENT GATEWAY - RAZORPAY
# ========================================
RAZORPAY_KEY_ID=your_razorpay_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret
RAZORPAY_WEBHOOK_SECRET=your_webhook_secret

# ========================================
# PAYMENT GATEWAY - STRIPE
# ========================================
STRIPE_PUBLISHABLE_KEY=your_stripe_publishable_key
STRIPE_SECRET_KEY=your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=your_stripe_webhook_secret

# ========================================
# FILE UPLOAD - CLOUDINARY
# ========================================
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ========================================
# FILE UPLOAD - AWS S3 (Alternative)
# ========================================
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_REGION=ap-south-1
AWS_BUCKET_NAME=umrahconnect-uploads

# ========================================
# SMS CONFIGURATION - TWILIO
# ========================================
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+1234567890

# ========================================
# SMS CONFIGURATION - MSG91 (India)
# ========================================
MSG91_AUTH_KEY=your_msg91_auth_key
MSG91_SENDER_ID=UMRAHC
MSG91_ROUTE=4

# ========================================
# WHATSAPP CONFIGURATION
# ========================================
WHATSAPP_API_KEY=your_whatsapp_api_key
WHATSAPP_PHONE_NUMBER=+919876543210

# ========================================
# GOOGLE SERVICES
# ========================================
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_CALLBACK_URL=http://localhost:5000/api/auth/google/callback

# Google Analytics
GOOGLE_ANALYTICS_ID=UA-XXXXXXXXX-X

# Google Maps
GOOGLE_MAPS_API_KEY=your_google_maps_api_key

# ========================================
# SOCIAL MEDIA LOGIN
# ========================================
FACEBOOK_APP_ID=your_facebook_app_id
FACEBOOK_APP_SECRET=your_facebook_app_secret
FACEBOOK_CALLBACK_URL=http://localhost:5000/api/auth/facebook/callback

# ========================================
# RATE LIMITING
# ========================================
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# ========================================
# CORS CONFIGURATION
# ========================================
CORS_ORIGIN=http://localhost:3000

# ========================================
# SESSION CONFIGURATION
# ========================================
SESSION_SECRET=your-session-secret-key-change-this
SESSION_EXPIRE=86400000

# ========================================
# REDIS CONFIGURATION (Optional - for caching)
# ========================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ========================================
# LOGGING
# ========================================
LOG_LEVEL=info
LOG_FILE=logs/app.log

# ========================================
# ADMIN CREDENTIALS (First Time Setup)
# ========================================
ADMIN_NAME=Admin User
ADMIN_EMAIL=admin@umrahconnect.com
ADMIN_PASSWORD=Admin@123456
ADMIN_PHONE=+919876543210

# ========================================
# SITE CONFIGURATION
# ========================================
SITE_NAME=UmrahConnect
SITE_URL=http://localhost:3000
SITE_DESCRIPTION=Your Trusted Partner for Sacred Journeys

# ========================================
# CURRENCY CONFIGURATION
# ========================================
DEFAULT_CURRENCY=INR
CURRENCY_SYMBOL=₹

# ========================================
# BOOKING CONFIGURATION
# ========================================
BOOKING_PREFIX=BK
MIN_BOOKING_ADVANCE_DAYS=7
MAX_BOOKING_ADVANCE_DAYS=365
CANCELLATION_DEADLINE_DAYS=7

# ========================================
# NOTIFICATION CONFIGURATION
# ========================================
ENABLE_EMAIL_NOTIFICATIONS=true
ENABLE_SMS_NOTIFICATIONS=true
ENABLE_WHATSAPP_NOTIFICATIONS=true
ENABLE_PUSH_NOTIFICATIONS=true

# ========================================
# MAINTENANCE MODE
# ========================================
MAINTENANCE_MODE=false
MAINTENANCE_MESSAGE=We are currently under maintenance. Please check back soon.

# ========================================
# SECURITY
# ========================================
MAX_LOGIN_ATTEMPTS=5
LOCK_TIME=7200000
PASSWORD_RESET_EXPIRE=600000
EMAIL_VERIFICATION_EXPIRE=86400000

# ========================================
# FILE UPLOAD LIMITS
# ========================================
MAX_FILE_SIZE=10485760
ALLOWED_FILE_TYPES=image/jpeg,image/png,image/jpg,application/pdf

# ========================================
# PAGINATION
# ========================================
DEFAULT_PAGE_SIZE=10
MAX_PAGE_SIZE=100

# ========================================
# CACHE CONFIGURATION
# ========================================
CACHE_TTL=3600
ENABLE_CACHE=true

# ========================================
# API VERSIONING
# ========================================
API_VERSION=v1

# ========================================
# THIRD PARTY INTEGRATIONS
# ========================================
# Visa Processing API
VISA_API_KEY=your_visa_api_key
VISA_API_URL=https://api.visaprocessing.com

# Flight Booking API
FLIGHT_API_KEY=your_flight_api_key
FLIGHT_API_URL=https://api.flightbooking.com

# Hotel Booking API
HOTEL_API_KEY=your_hotel_api_key
HOTEL_API_URL=https://api.hotelbooking.com

# ========================================
# MONITORING & ANALYTICS
# ========================================
SENTRY_DSN=your_sentry_dsn
NEW_RELIC_LICENSE_KEY=your_newrelic_key

# ========================================
# BACKUP CONFIGURATION
# ========================================
BACKUP_ENABLED=true
BACKUP_SCHEDULE=0 2 * * *
BACKUP_RETENTION_DAYS=30

# ========================================
# TESTING
# ========================================
TEST_DATABASE_URI=mongodb://localhost:27017/umrahconnect_test
TEST_JWT_SECRET=test-jwt-secret
