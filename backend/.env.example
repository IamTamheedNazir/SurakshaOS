# ============================================
# UMRAHCONNECT 2.0 - ENVIRONMENT VARIABLES
# ============================================

# ============================================
# SERVER CONFIGURATION
# ============================================
NODE_ENV=development
PORT=5000
API_VERSION=v1
BASE_URL=http://localhost:5000

# Frontend URL (for CORS and redirects)
FRONTEND_URL=http://localhost:3000

# ============================================
# DATABASE CONFIGURATION (PostgreSQL)
# ============================================
DB_HOST=localhost
DB_PORT=5432
DB_NAME=umrahconnect_db
DB_USER=postgres
DB_PASSWORD=your_secure_password
DB_DIALECT=postgres
DB_POOL_MAX=10
DB_POOL_MIN=2
DB_POOL_ACQUIRE=30000
DB_POOL_IDLE=10000

# Database SSL (set to true for production)
DB_SSL=false

# ============================================
# JWT CONFIGURATION
# ============================================
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
JWT_EXPIRE=7d
JWT_REFRESH_SECRET=your_refresh_token_secret_key
JWT_REFRESH_EXPIRE=30d

# ============================================
# WASABI S3 CONFIGURATION
# ============================================
# Wasabi Endpoint (choose based on your region)
# us-east-1: https://s3.wasabisys.com
# us-east-2: https://s3.us-east-2.wasabisys.com
# us-west-1: https://s3.us-west-1.wasabisys.com
# eu-central-1: https://s3.eu-central-1.wasabisys.com
# ap-northeast-1: https://s3.ap-northeast-1.wasabisys.com

WASABI_ENDPOINT=https://s3.wasabisys.com
WASABI_REGION=us-east-1
WASABI_ACCESS_KEY_ID=your_wasabi_access_key
WASABI_SECRET_ACCESS_KEY=your_wasabi_secret_key
WASABI_BUCKET_NAME=umrahconnect-storage

# S3 Folders
S3_FOLDER_USERS=users
S3_FOLDER_VENDORS=vendors
S3_FOLDER_PACKAGES=packages
S3_FOLDER_DOCUMENTS=documents
S3_FOLDER_REPORTS=reports
S3_FOLDER_INVOICES=invoices

# ============================================
# EMAIL CONFIGURATION (Nodemailer)
# ============================================
# SMTP Configuration
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_specific_password

# Email From
EMAIL_FROM=noreply@umrahconnect.com
EMAIL_FROM_NAME=UmrahConnect

# Email Templates
EMAIL_VERIFICATION_SUBJECT=Verify Your Email - UmrahConnect
PASSWORD_RESET_SUBJECT=Reset Your Password - UmrahConnect
BOOKING_CONFIRMATION_SUBJECT=Booking Confirmed - UmrahConnect

# ============================================
# GOOGLE OAUTH CONFIGURATION
# ============================================
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_CALLBACK_URL=http://localhost:5000/api/v1/auth/google/callback

# ============================================
# FACEBOOK OAUTH CONFIGURATION
# ============================================
FACEBOOK_APP_ID=your_facebook_app_id
FACEBOOK_APP_SECRET=your_facebook_app_secret
FACEBOOK_CALLBACK_URL=http://localhost:5000/api/v1/auth/facebook/callback

# ============================================
# REDIS CONFIGURATION (Optional - for sessions)
# ============================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_TTL=3600

# Session Secret
SESSION_SECRET=your_session_secret_key_change_this

# ============================================
# RATE LIMITING
# ============================================
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Auth Rate Limiting (stricter)
AUTH_RATE_LIMIT_WINDOW_MS=900000
AUTH_RATE_LIMIT_MAX_REQUESTS=5

# ============================================
# FILE UPLOAD LIMITS
# ============================================
MAX_FILE_SIZE=10485760
MAX_FILES_PER_UPLOAD=5
ALLOWED_FILE_TYPES=image/jpeg,image/png,image/jpg,application/pdf,application/msword,application/vnd.openxmlformats-officedocument.wordprocessingml.document

# ============================================
# PAYMENT GATEWAY (Future Integration)
# ============================================
# Razorpay
RAZORPAY_KEY_ID=your_razorpay_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret

# Stripe
STRIPE_PUBLIC_KEY=your_stripe_public_key
STRIPE_SECRET_KEY=your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=your_stripe_webhook_secret

# ============================================
# SMS GATEWAY (Future Integration)
# ============================================
# Twilio
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+1234567890

# MSG91
MSG91_AUTH_KEY=your_msg91_auth_key
MSG91_SENDER_ID=UMRAHC

# ============================================
# LOGGING
# ============================================
LOG_LEVEL=info
LOG_FILE_PATH=logs/app.log
LOG_ERROR_FILE_PATH=logs/error.log

# ============================================
# SECURITY
# ============================================
# Password Reset Token Expiry (in minutes)
PASSWORD_RESET_TOKEN_EXPIRE=60

# Email Verification Token Expiry (in hours)
EMAIL_VERIFICATION_TOKEN_EXPIRE=24

# OTP Expiry (in minutes)
OTP_EXPIRE=10

# Bcrypt Salt Rounds
BCRYPT_SALT_ROUNDS=10

# ============================================
# CORS CONFIGURATION
# ============================================
CORS_ORIGIN=http://localhost:3000,https://umrahconnect.com
CORS_CREDENTIALS=true

# ============================================
# MONITORING & ANALYTICS (Optional)
# ============================================
# Sentry (Error Tracking)
SENTRY_DSN=your_sentry_dsn

# Google Analytics
GA_TRACKING_ID=UA-XXXXXXXXX-X

# ============================================
# FEATURE FLAGS
# ============================================
ENABLE_EMAIL_VERIFICATION=true
ENABLE_SMS_VERIFICATION=false
ENABLE_SOCIAL_LOGIN=true
ENABLE_TWO_FACTOR_AUTH=false
ENABLE_AUDIT_LOGS=true

# ============================================
# BUSINESS CONFIGURATION
# ============================================
# Company Details
COMPANY_NAME=UmrahConnect
COMPANY_EMAIL=support@umrahconnect.com
COMPANY_PHONE=+91-XXXXXXXXXX
COMPANY_ADDRESS=Your Company Address

# Support
SUPPORT_EMAIL=support@umrahconnect.com
SUPPORT_PHONE=+91-XXXXXXXXXX

# ============================================
# DEVELOPMENT ONLY
# ============================================
# Set to true to enable detailed error messages
DEBUG=false

# Set to true to seed database with sample data
SEED_DATABASE=false
